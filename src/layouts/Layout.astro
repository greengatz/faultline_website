---
import Header from '../components/Header.astro';
import faviconImage from '../assets/maelstrom-dice_2x.png';

interface Props {
  title?: string;
}

const { title = "Faultline 40k" } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href={faviconImage.src} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
    <!-- Google Fonts Inter & Quantico -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Quantico:ital,wght@0,400;0,700;1,400;1,700&display=swap" rel="stylesheet">
	</head>
	<body>
		<Header />
    <main class="main-content">
      <slot />
    </main>
    <footer class="footer">
      <div class="container">
        <p>&copy; {new Date().getFullYear()} Faultline Tabletop Gaming. All rights reserved.</p>
      </div>
    </footer>
	</body>
</html>

<style is:global>
  :root {
    /* Theme independent variables */
    --accent: #3ea9f5;
    --accent-hover: #2693e0;
    --accent-glow: rgba(62, 169, 245, 0.15);
    --font-sans: 'Inter', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    --font-display: 'Quantico', var(--font-sans);

    /* Dark Theme (Default) */
    --bg-primary: #121214;
    --bg-secondary: #1a1a1e;
    --bg-header: rgba(30, 30, 35, 0.85);
    --bg-footer: rgba(30, 30, 35, 0.85);
    --border: rgba(255, 255, 255, 0.08);
    --border-header: rgba(255, 255, 255, 0.1);
    
    --text-primary: #f4f4f5;
    --text-secondary: #a1a1aa;
    --text-logo: #ffffff;
    --text-nav-hover: #ffffff;

    --btn-secondary-hover-bg: rgba(255, 255, 255, 0.05);
    --btn-secondary-hover-border: rgba(255, 255, 255, 0.2);
  }

  /* Media Query for System-level Light Theme */
  @media (prefers-color-scheme: light) {
    :root {
      --accent: #128EE6;
      --accent-hover: #0f7dcc;
      --bg-primary: #FFE5D1;
      --bg-secondary: #FDF0E6;
      --bg-header: rgba(255, 193, 145, 0.85);
      --bg-footer: #FFC191;
      --border: rgba(0, 0, 0, 0.08);
      --border-header: rgba(0, 0, 0, 0.08);

      --text-primary: #18181b;
      --text-secondary: #52525b;
      --text-logo: #18181b;
      --text-nav-hover: #18181b;

      --btn-secondary-hover-bg: rgba(0, 0, 0, 0.03);
      --btn-secondary-hover-border: rgba(0, 0, 0, 0.15);

      --accent-glow: rgba(18, 142, 230, 0.1);
    }
  }

  /* Manual Override Classes for Testing/Forcing Themes */
  html.theme-dark {
    --bg-primary: #121214;
    --bg-secondary: #1a1a1e;
    --bg-header: rgba(30, 30, 35, 0.85);
    --bg-footer: rgba(30, 30, 35, 0.85);
    --border: rgba(255, 255, 255, 0.08);
    --border-header: rgba(255, 255, 255, 0.1);
    
    --text-primary: #f4f4f5;
    --text-secondary: #a1a1aa;
    --text-logo: #ffffff;
    --text-nav-hover: #ffffff;

    --btn-secondary-hover-bg: rgba(255, 255, 255, 0.05);
    --btn-secondary-hover-border: rgba(255, 255, 255, 0.2);
    --accent-glow: rgba(62, 169, 245, 0.15);
  }

  html.theme-light {
    --accent: #128EE6;
    --accent-hover: #0f7dcc;
    --bg-primary: #FFE5D1;
    --bg-secondary: #FDF0E6;
    --bg-header: rgba(255, 193, 145, 0.85);
    --bg-footer: #FFC191;
    --border: rgba(0, 0, 0, 0.08);
    --border-header: rgba(0, 0, 0, 0.08);

    --text-primary: #18181b;
    --text-secondary: #52525b;
    --text-logo: #18181b;
    --text-nav-hover: #18181b;

    --btn-secondary-hover-bg: rgba(0, 0, 0, 0.03);
    --btn-secondary-hover-border: rgba(0, 0, 0, 0.15);

    --accent-glow: rgba(18, 142, 230, 0.1);
  }

	html,
	body {
		margin: 0;
		padding: 0;
		width: 100%;
		min-height: 100vh;
    background-color: var(--bg-primary);
    color: var(--text-primary);
    font-family: var(--font-sans);
    display: flex;
    flex-direction: column;
    overflow-x: hidden;
	}

  * {
    box-sizing: border-box;
  }

  .main-content {
    flex: 1 0 auto;
    display: flex;
    flex-direction: column;
    width: 100%;
  }

  .footer {
    flex-shrink: 0;
    border-top: 1px solid var(--border);
    padding: 2rem 0;
    background-color: var(--bg-footer);
    text-align: center;
    color: var(--text-secondary);
    font-size: 0.875rem;
  }

  .footer .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* Utility styling for buttons / links */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 1.5rem;
    font-size: 0.95rem;
    font-weight: 600;
    border-radius: 8px;
    text-decoration: none;
    transition: all 0.2s ease;
    cursor: pointer;
  }

  .btn-primary {
    background-color: var(--accent);
    color: #ffffff;
    border: none;
    box-shadow: 0 4px 12px var(--accent-glow);
  }

  .btn-primary:hover {
    background-color: var(--accent-hover);
    transform: translateY(-2px);
    box-shadow: 0 6px 16px var(--accent-glow);
  }

  .btn-secondary {
    background-color: transparent;
    color: var(--text-primary);
    border: 1px solid var(--border);
  }

  .btn-secondary:hover {
    background-color: var(--btn-secondary-hover-bg);
    border-color: var(--btn-secondary-hover-border);
    transform: translateY(-2px);
  }

  /* Typography Helper */
  h1, h2, h3, h4, h5, h6, .logo, .nav-link, .btn, strong {
    font-family: var(--font-display);
  }

  h1, h2, h3, h4, h5, h6 {
    margin: 0 0 1rem 0;
    font-weight: 700;
    line-height: 1.25;
    letter-spacing: -0.02em;
  }

  p {
    margin: 0 0 1.5rem 0;
    line-height: 1.6;
    color: var(--text-secondary);
  }
</style>
